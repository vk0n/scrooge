# --- Bot credentials ---
BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me

# --- GUI auth (required) ---
SCROOGE_GUI_USERNAME=admin
SCROOGE_GUI_PASSWORD=replace_with_strong_password

# --- Optional machine token for /api/control/* ---
SCROOGE_CONTROL_TOKEN=

# --- Command queue (Redis) ---
SCROOGE_REDIS_HOST=redis
SCROOGE_REDIS_PORT=6379
SCROOGE_REDIS_DB=0
SCROOGE_CONTROL_QUEUE_KEY=scrooge:control:queue
SCROOGE_COMMAND_STATUS_PREFIX=scrooge:control:command:
SCROOGE_COMMAND_STATUS_TTL_SECONDS=86400
SCROOGE_LIVE_POLL_SECONDS=60
SCROOGE_CONTROL_POLL_SLICE_SECONDS=1
SCROOGE_WS_PUSH_INTERVAL_SECONDS=2
SCROOGE_WS_LOG_LINES=200

# --- Optional API CORS override ---
SCROOGE_GUI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend/API internal wiring ---
INTERNAL_API_BASE_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=
