# --- Bot credentials ---
BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me

# --- GUI auth (required) ---
SCROOGE_GUI_USERNAME=admin
SCROOGE_GUI_PASSWORD=replace_with_strong_password

# --- Optional machine token for /api/control/* ---
SCROOGE_CONTROL_TOKEN=

# --- Command queue (Redis) ---
SCROOGE_REDIS_HOST=redis
SCROOGE_REDIS_PORT=6379
SCROOGE_REDIS_DB=0
SCROOGE_CONTROL_QUEUE_KEY=scrooge:control:queue
SCROOGE_COMMAND_STATUS_PREFIX=scrooge:control:command:
SCROOGE_COMMAND_STATUS_TTL_SECONDS=86400
SCROOGE_LIVE_POLL_SECONDS=60
SCROOGE_CONTROL_POLL_SLICE_SECONDS=1
SCROOGE_MARKET_STREAM_ENABLED=1
SCROOGE_MARKET_STREAM_PERSIST_INTERVAL_SECONDS=1
SCROOGE_MARKET_STREAM_SETTLE_SECONDS=1.5
SCROOGE_USER_STREAM_ENABLED=1
SCROOGE_USER_STREAM_KEEPALIVE_SECONDS=1800
SCROOGE_USER_STREAM_RECONNECT_SECONDS=5
SCROOGE_USER_STREAM_STALE_AFTER_SECONDS=120
SCROOGE_FUTURES_REST_BASE_URL=https://fapi.binance.com
SCROOGE_FUTURES_WS_BASE_URL=wss://fstream.binance.com/ws
SCROOGE_DEBUG_STRATEGY_TICKS=0
SCROOGE_RUNTIME_MODE=live
SCROOGE_STRATEGY_MODE=discrete
SCROOGE_CONFIG_PATH=/runtime/config.yaml
SCROOGE_LOG_FILE=/runtime/trading_log.txt
SCROOGE_EVENT_LOG_FILE=/runtime/event_history.jsonl
SCROOGE_WS_PUSH_INTERVAL_SECONDS=2
SCROOGE_WS_LOG_LINES=200
SCROOGE_CHART_MAX_CANDLES=1500
SCROOGE_CHART_DATASET_MAX_CANDLES=10000
SCROOGE_CHART_TIMEOUT_SECONDS=10
SCROOGE_CHART_SOURCE=auto
SCROOGE_CHART_DATASET_PATH=/runtime/chart_dataset.csv
SCROOGE_RUNTIME_CHART_DATASET_PATH=/runtime/chart_dataset.csv
SCROOGE_STATE_FILE=/runtime/state.json
SCROOGE_TRADE_HISTORY_FILE=/runtime/trade_history.jsonl
SCROOGE_BALANCE_HISTORY_FILE=/runtime/balance_history.jsonl
SCROOGE_TRADE_HISTORY_PATH=/runtime/trade_history.jsonl
SCROOGE_BALANCE_HISTORY_PATH=/runtime/balance_history.jsonl
SCROOGE_BACKTEST_CONFIG_PATH=/runtime/config.backtest.yaml
SCROOGE_BACKTEST_ROOT=/runtime/backtests
SCROOGE_HOST_BACKTEST_ARTIFACTS_DIR=./backtest_artifacts

# --- Optional API CORS override ---
SCROOGE_GUI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend/API internal wiring ---
INTERNAL_API_BASE_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=

# --- Optional image refs for registry-based deploys / Watchtower ---
SCROOGE_BOT_IMAGE=vk0n/scrooge-bot:latest
SCROOGE_BACKTEST_IMAGE=vk0n/scrooge-bot:latest
SCROOGE_API_IMAGE=vk0n/scrooge-api:latest
SCROOGE_FRONTEND_IMAGE=vk0n/scrooge-frontend:latest
SCROOGE_PROXY_IMAGE=nginx:1.27-alpine

# --- Optional Watchtower auto-update ---
SCROOGE_WATCHTOWER_SCOPE=scrooge
SCROOGE_WATCHTOWER_POLL_INTERVAL=300
SCROOGE_WATCHTOWER_HTTP_API_TOKEN=
